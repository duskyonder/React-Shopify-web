{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/blogs/news",
      "destination": "/pages/blog",
      "permanent": true
    },
    {
      "source": "/blogs/news/:path*",
      "destination": "/pages/blog/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/manus-storage/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets|_next|favicon\\.ico|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
